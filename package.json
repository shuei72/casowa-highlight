{
  "name": "casowa-highlight",
  "displayName": "Casowa Highlight",
  "description": "VS Code extension to highlight words with 16 configurable color patterns.",
  "version": "0.0.1",
  "publisher": "shuei",
  "author": "shuei",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shuei72/casowa-highlight.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "highlight",
    "word highlight",
    "text highlight",
    "vscode"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "casowaHighlight.highlightCurrentWord",
        "title": "Casowa Highlight: Highlight Current Word"
      },
      {
        "command": "casowaHighlight.highlightInputWord",
        "title": "Casowa Highlight: Highlight Word from Input"
      },
      {
        "command": "casowaHighlight.clearCurrentWordHighlight",
        "title": "Casowa Highlight: Clear Current Word Highlight"
      },
      {
        "command": "casowaHighlight.clearAllHighlights",
        "title": "Casowa Highlight: Clear All Highlights"
      }
    ],
    "configuration": {
      "title": "Casowa Highlight",
      "properties": {
        "casowaHighlight.pattern1.backgroundColor": {
          "type": "string",
          "default": "#FFF59D",
          "description": "Background color for highlight pattern 1."
        },
        "casowaHighlight.pattern1.foregroundColor": {
          "type": "string",
          "default": "#1F1F1F",
          "description": "Foreground color for highlight pattern 1."
        },
